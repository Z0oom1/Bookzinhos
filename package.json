{
  "name": "bookzinhos",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev:web": "npm run dev --prefix frontend",
    "dev:server": "npm start --prefix server",
    "build:web": "npm run build --prefix frontend",
    "copy:web": "node scripts/copy-web.js",
    "prebuild:apk": "npm run build:web && npm run copy:web",
    "build:apk": "set EAS_NO_VCS=1&& npx eas-cli build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "latest",
    "@react-navigation/native": "latest",
    "@react-navigation/native-stack": "latest",
    "@supabase/supabase-js": "^2.104.0",
    "dotenv": "^17.4.2",
    "expo": "^54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pdf": "latest",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
